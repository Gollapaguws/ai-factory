# Local development defaults
NODE_ENV=development
HOST_BIND=127.0.0.1
POSTGRES_USER=ai
POSTGRES_PASSWORD=change-this-postgres-password
POSTGRES_DB=ai_factory
DATABASE_URL=postgres://ai:change-this-postgres-password@postgres:5432/ai_factory
REDIS_URL=redis://redis:6379
NEXT_PUBLIC_API_URL=http://localhost:3000

# Production hardening
JWT_SECRET=change-this-to-a-long-random-secret
JWT_TTL=12h
JWT_ISSUER=ai-factory
JWT_AUDIENCE=web-console
CORS_ORIGIN=https://your-web-domain.example.com
ALLOW_SELF_REGISTER=false
ALLOWED_USERS=engineer1@example.com,engineer2@example.com
OAUTH_PROVIDER=google
